# NeuroMeshOSS Core Environment Variables

# App Environment (dev, staging, prod)
ENV=dev
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://neuromesh:neuromesh_secure_pass@localhost:5432/neuromesh_db

# Cache & Message Broker (Redis)
REDIS_URL=redis://localhost:6379/0

# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333

# Object Storage (MinIO / S3)
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=neuromesh_root
STORAGE_SECRET_KEY=neuromesh_root_secure_pass
STORAGE_SECURE=false
STORAGE_BUCKET_NAME=neuromesh-artifacts

# Authentication Framework
JWT_SECRET_KEY=neuromesh_super_secret_jwt_sign_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Envelope Cryptography Key for Secrets-at-Rest (AES-256 base64-encoded)
# Generate via: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=WjVnd1B4NzdWUWNJU2pIejh0Tk9jREp0UWxVbWpLczI=

# OpenTelemetry Metrics & Distributed Tracing
OTEL_SERVICE_NAME=neuromesh-core
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Local LLM Engine (Ollama)
OLLAMA_HOST=http://localhost:11434

# External Model Providers (Optional)
OPENAI_API_KEY=
OPENAI_API_BASE=
ANTHROPIC_API_KEY=
